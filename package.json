{
  "name": "abivax",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:spine-smoke": "powershell -ExecutionPolicy Bypass -File scripts/dev_smoke_checks.ps1",
    "entity:build": "node scripts/build_entity_profiles.js",
    "verify:connectivity": "node scripts/verify_connectivity.js",
    "calendar:sync-today": "powershell -ExecutionPolicy Bypass -File scripts/sync_todays_calendar.ps1 && node scripts/merge_todays_meetings.js",
    "email:scan-context": "powershell -ExecutionPolicy Bypass -File scripts/export_recent_emails.ps1 -DaysBack 2 -MaxItems 300 && node scripts/analyze_email_context.js",
    "email:sync-context": "powershell -ExecutionPolicy Bypass -File scripts/export_recent_emails.ps1 -DaysBack 2 -MaxItems 300 && node scripts/analyze_email_context.js --write-entities",
    "email:export-sent": "powershell -ExecutionPolicy Bypass -File scripts/export_recent_sent_emails.ps1 -DaysBack 5 -MaxItems 300",
    "email:sanitize-ingest": "node scripts/sanitize_email_ingest_artifacts.js",
    "context:operating": "node scripts/build_operating_context.js",
    "email:export-cfti-attachments": "powershell -ExecutionPolicy Bypass -File scripts/export_cfti_control_attachments.ps1",
    "agent:pillar-email-sync": "node scripts/reconcile_pillar_email_status.js",
    "agent:cfti-controls-intake": "node scripts/build_cfti_controls_intake.js",
    "agent:cfti-control-register": "node scripts/build_cfti_control_register.js",
    "agent:trinidad-p2p-bundle": "node scripts/extract_trinidad_p2p_bundle.js",
    "agent:process-flow-overlays": "node scripts/build_process_flow_control_overlays.js",
    "agent:process-flow-diagrams": "node scripts/build_process_flow_diagram_payloads.js",
    "agent:sharepoint-ingest": "node scripts/ingest_sharepoint_artifacts.js",
    "agent:sharepoint-content": "node scripts/process_sharepoint_local_content.js",
    "agent:sharepoint-graph-sync": "powershell -ExecutionPolicy Bypass -File scripts/sync_sharepoint_graph.ps1",
    "agent:meeting-attendee-seed": "node scripts/seed_meeting_attendee_entities.js",
    "agent:treasury-extract": "node scripts/extract_treasury_workbooks.js",
    "agent:engage-extract": "node scripts/extract_engage_2026.js",
    "org:sync-graph": "powershell -ExecutionPolicy Bypass -File scripts/sync_org_graph.ps1",
    "agent:org-merge": "node scripts/merge_org_graph_into_entities.js",
    "agent:people-dedupe": "node scripts/reconcile_duplicate_people.js",
    "note:sync": "node scripts/link_note_entities.js",
    "note:pipeline": "powershell -ExecutionPolicy Bypass -File scripts/run_note_pipeline.ps1 && npm run entity:build && npm run verify:connectivity",
    "presentations:build": "powershell -ExecutionPolicy Bypass -File scripts/generate_presentations.ps1",
    "agent:people-canonical": "node scripts/reconcile_people_entities.js",
    "agent:wiki-specificity": "node scripts/check_wiki_specificity.js",
    "agent:person-quality": "node scripts/analyze_person_content_quality.js",
    "agent:person-redundancy": "node scripts/check_person_profile_redundancy.js",
    "agent:person-relevance": "node scripts/check_person_relevance_mismatch.js",
    "agent:wiki-queue": "node scripts/build_wiki_review_queue.js",
    "agent:wiki-agent-backlog": "node scripts/analyze_wiki_agent_backlog.js",
    "agent:page-readability": "node scripts/analyze_page_readability_signals.js",
    "agent:today-content-quality": "node scripts/analyze_today_content_quality.js",
    "agent:daily-close-summary": "node scripts/build_daily_close_summary.js",
    "agent:claude-lane-queue": "node scripts/build_claude_lane_queue.js",
    "agent:claude-next-prompt": "node scripts/build_claude_next_prompt.js",
    "agent:feed-impact": "node scripts/score_feed_impact.js",
    "agent:nav-governance": "node scripts/nav_governance_audit.js",
    "agent:focus-prompts": "node scripts/generate_operator_focus_prompts.js",
    "agent:company-intel-digest": "node scripts/build_company_intel_digest.js",
    "agent:company-intel-ir": "node scripts/sync_company_intel_ir_feed.js",
    "agent:company-intel-ir-email": "node scripts/sync_company_intel_ir_email_feed.js",
    "agent:company-intel-sec": "node scripts/sync_company_intel_sec_feed.js",
    "agent:company-intel-queue": "node scripts/build_company_intel_review_queue.js",
    "agent:company-intel-agent-backlog": "node scripts/analyze_company_intel_agent_backlog.js",
    "agents:swarm": "powershell -ExecutionPolicy Bypass -File scripts/run_agent_swarm.ps1",
    "agents:waterfall": "powershell -ExecutionPolicy Bypass -File scripts/run_swarm_waterfall.ps1",
    "agents:waterfall:failfast": "powershell -ExecutionPolicy Bypass -File scripts/run_swarm_waterfall.ps1 -FailFast",
    "agents:waterfall:downstream": "powershell -ExecutionPolicy Bypass -File scripts/run_swarm_waterfall.ps1 -Stages enrich,detect,outputs",
    "agents:waterfall:review": "node scripts/analyze_swarm_waterfall_review.js"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
